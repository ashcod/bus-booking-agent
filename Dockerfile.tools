# Dockerfile.tools — MCP tool server
FROM python:3.11-slim

RUN pip install uv

WORKDIR /app

COPY pyproject.toml .
COPY uv.lock* .

RUN uv sync --frozen --no-dev

COPY app/ ./app/
COPY data/ ./data/

ENV DEPLOYMENT_MODE=cloud

EXPOSE 8001

CMD ["uv", "run", "uvicorn", "app.tools.tool_server:app", \
     "--host", "0.0.0.0", "--port", "8001"]