# Copy this file to .env and fill in your values
# Never commit .env to Git — it is in .gitignore

# LLM provider — get free key at console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# LangSmith tracing — get free key at smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your_langsmith_key_here
LANGCHAIN_PROJECT=bus-booking-agent

# Embedding provider — ollama (local) or sentence-transformers (cloud)
EMBEDDING_PROVIDER=ollama

# Infrastructure URLs
QDRANT_URL=http://localhost:6333
TOOL_SERVER_URL=http://localhost:8001